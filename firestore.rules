rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Project is paused: the leaderboard data is frozen read-only.
    // Public reads keep the deployed rankings working; all writes are denied
    // to prevent tampering with the existing records. Re-enable writes here
    // (e.g. scoped to request.auth) if the project is ever resumed.
    match /mlbbUsers/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else. The client-side rate-limit collections
    // (rateLimits / ipRateLimits) are no longer used now that writes are off.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
