rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read AND write access to mlbbUsers collection
    match /mlbbUsers/{userId} {
      allow read, write: if true;
    }
    
    // Rate limits collection - allow read/write for IP rate limiting
    match /ipRateLimits/{ipHash} {
      allow read, write: if true;
    }
    
    // Allow read/write to rateLimits collection
    match /rateLimits/{userId} {
      allow read, write: if true;
    }
    
    // All other collections require authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
} 