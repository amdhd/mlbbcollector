rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Frozen: existing profile images stay publicly readable so the deployed
    // leaderboard renders; no new uploads are permitted while paused.
    match /profile-images/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Everything else: no access (previously all paths were world-readable).
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
