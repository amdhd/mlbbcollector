rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read files
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Allow anyone to upload to profile-images folder
    match /profile-images/{fileName} {
      allow write: if true; // This allows unauthenticated uploads as well
    }
    
    // If you need to add other paths later, add them here
  }
} 